{
  "expo": {
    "name": "Lexify",
    "slug": "lexify",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080808"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lexify.app",
      "buildNumber": "7",
      "infoPlist": {
        "NSCameraUsageDescription": "Kitap ve metinlerdeki kelimeleri taramak için kamera kullanılır.",
        "NSPhotoLibraryUsageDescription": "Galeriden resim seçmek için kullanılır.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "versionCode": 7,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080808"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      "expo-web-browser",
      "expo-font"
    ],
    "scheme": "lexitr",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "89faf227-9472-45e6-a040-0371abfda167"
      }
    }
  }
}
