modules = ["nodejs-20"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
integrations = ["javascript_database:1.0.0"]

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
REVENUECAT_PROJECT_ID = "proj2f69bb99"
REVENUECAT_TEST_STORE_APP_ID = "app7e8ef49947"
REVENUECAT_APPLE_APP_STORE_APP_ID = "appe18e928114"
REVENUECAT_GOOGLE_PLAY_STORE_APP_ID = "appc5353aaa91"
EXPO_PUBLIC_REVENUECAT_TEST_API_KEY = "test_uUdmAFrfYoyFYvTIwCVlwUsFtwp"
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY = "appl_cBbyFxbEtRIadLvTBTHlIeSlUCG"
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY = "goog_guJMqKmKUcyTdsNhuVcElFZMKKZ"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Expo Dev Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node proxy.js"
waitForPort = 5000

[[workflows.workflow]]
name = "Expo Dev Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx expo start --web --port 8080"
waitForPort = 8080

[[workflows.workflow]]
name = "API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node server/index.js"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3000
externalPort = 3002

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[deployment]
deploymentTarget = "autoscale"
run = ["npx", "expo", "start", "--web", "--port", "5000"]
