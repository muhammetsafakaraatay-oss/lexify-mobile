# Kopyala: cp .env.example .env
# EAS Build için: expo.dev → Project → Environment variables (preview + production)

EXPO_PUBLIC_API_BASE=https://lexitr.vercel.app
OPENAI_API_KEY=
EXPO_PUBLIC_OPENAI_PROXY_URL=/api/llm-call

# ─── Gemini (Writing AI feedback) ─────────────────────────────────────────────
# App doğrudan Gemini'ye konuşur — backend gerekmez.
# Ücretsiz key: https://aistudio.google.com/apikey (1500 istek/gün, 15/dakika)
EXPO_PUBLIC_GEMINI_API_KEY=
EXPO_PUBLIC_GEMINI_MODEL=gemini-2.0-flash

# ─── Free-tier AI providers (server-side only, opsiyonel) ─────────────────────
# Bu key'ler proxy.js veya Vercel route üzerinden kullanılır.
# Mobile app sadece EXPO_PUBLIC_* prefix'li env var'ları okuyabilir.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Groq Llama 3.3 70B — ücretsiz + çok hızlı: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
